enum AuditActorType {
  USER
  ADMIN
  SYSTEM
  INTEGRATION
  JOB
  ANONYMOUS
}

enum AuditOutcome {
  SUCCESS
  FAILURE
  DENIED
  VALIDATION_ERROR
}

enum AuditSeverity {
  DEBUG
  INFO
  WARNING
  ERROR
  CRITICAL
}

model AuditEvent {
  id String @id @default(uuid()) @db.Uuid

  action   String        @db.VarChar(120)
  category String?       @db.VarChar(80)
  outcome  AuditOutcome  @default(SUCCESS)
  severity AuditSeverity @default(INFO)

  actorType   AuditActorType @default(USER) @map("actor_type")
  actorId     String?        @map("actor_id") @db.VarChar(191)
  actorUserId String?        @map("actor_user_id") @db.Uuid
  actorRole   Role?          @map("actor_role")
  actorLogin  String?        @map("actor_login") @db.VarChar(191)
  actorName   String?        @map("actor_name") @db.VarChar(255)

  targetType      String? @map("target_type") @db.VarChar(100)
  targetId        String? @map("target_id") @db.VarChar(191)
  targetCatalogId String? @map("target_catalog_id") @db.Uuid
  targetLabel     String? @map("target_label") @db.VarChar(255)

  requestId     String? @map("request_id") @db.VarChar(100)
  correlationId String? @map("correlation_id") @db.VarChar(100)
  sessionId     String? @map("session_id") @db.VarChar(191)

  ip        String? @db.VarChar(64)
  userAgent String? @map("user_agent") @db.Text
  method    String? @db.VarChar(10)
  host      String? @db.VarChar(255)
  path      String? @db.VarChar(1024)
  statusCode Int?  @map("status_code")

  reason  String? @db.Text
  message String? @db.Text

  before   Json?
  after    Json?
  diff     Json?
  metadata Json?

  targets AuditEventTarget[]
  changes AuditEventChange[]

  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([action, createdAt])
  @@index([category, createdAt])
  @@index([outcome, createdAt])
  @@index([severity, createdAt])
  @@index([actorType, createdAt])
  @@index([actorUserId, createdAt])
  @@index([actorId, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([targetCatalogId, createdAt])
  @@index([requestId])
  @@index([correlationId])
  @@map("audit_events")
}

model AuditEventTarget {
  id String @id @default(uuid()) @db.Uuid

  eventId String     @map("event_id") @db.Uuid
  event   AuditEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  targetType String  @map("target_type") @db.VarChar(100)
  targetId   String? @map("target_id") @db.VarChar(191)
  catalogId  String? @map("catalog_id") @db.Uuid
  label      String? @db.VarChar(255)
  snapshot   Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([eventId])
  @@index([targetType, targetId])
  @@index([catalogId, createdAt])
  @@map("audit_event_targets")
}

model AuditEventChange {
  id String @id @default(uuid()) @db.Uuid

  eventId String     @map("event_id") @db.Uuid
  event   AuditEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  field    String @db.VarChar(255)
  oldValue Json?  @map("old_value")
  newValue Json?  @map("new_value")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([eventId])
  @@index([field])
  @@map("audit_event_changes")
}
