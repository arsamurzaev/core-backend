// ═══════════════════════════════════════════════════════════════════════════════
// CATALOGS — Каталоги (магазины, рестораны, бренды)
// ═══════════════════════════════════════════════════════════════════════════════
//
// Конкретные каталоги, привязанные к типу. Все каталоги одного типа
// имеют одинаковую структуру атрибутов.
//
// ┌──────────────────────────────────────────────────────────────┐
// │ id   │ catalog_type_id │ name        │ slug   │ domain       │
// ├──────────────────────────────────────────────────────────────┤
// │ uuid │ clothing_uuid   │ H&M         │ hm     │ paradox.ru   │
// │ uuid │ clothing_uuid   │ Zara        │ zara   │ c4.ru        │
// │ uuid │ restaurant_uuid │ KFC         │ kfc    │ attarcha.ru  │
// │ uuid │ restaurant_uuid │ McDonald's  │ mcdon  │ tbiliso.ru   │
// └──────────────────────────────────────────────────────────────┘

model Catalog {
  // Уникальный идентификатор каталога
  id String @id @default(uuid()) @db.Uuid

  // URL-friendly идентификатор (уникален глобально)
  // Пример: "hm", "zara", "kfc"
  // Используется: hm.myctlg.ru
  slug String @unique

  // Доменное имя каталога (уникален глобально)
  // Пример: "paradox.ru", "c4.ru", "attarcha.ru"
  // Используется: hm.myctlg.ru
  domain String? @unique

  // Название каталога для UI
  // Пример: "H&M", "Zara", "KFC", "McDonald's"
  name String

  // FK на тип каталога — определяет доступные атрибуты товаров
  // Пример: ссылка на "clothing" или "restaurant"
  type   Type   @relation(fields: [typeId], references: [id])
  typeId String @map("type_id") @db.Uuid

  // ─── Связи ───
  // Родительский каталог
  parent   Catalog? @relation("CatalogToCatalog", fields: [parentId], references: [id], onDelete: Cascade)
  parentId String?  @map("catalog_id") @db.Uuid

  // Дочерний каталог
  children Catalog[] @relation("CatalogToCatalog")

  user   User?   @relation(fields: [userId], references: [id])
  userId String? @db.Uuid

  promoCodeId String?    @map("promo_code_id") @db.Uuid
  promoCode   PromoCode? @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)

  payments            Payment[]
  activity            Activity[]
  region              Regionality[]
  config              CatalogConfig?
  settings            CatalogSettings?
  seoSettings         SeoSetting[]
  metrics             Metrics[]
  contacts            CatalogContact[]
  products            Product[]
  productTypes        ProductType[]
  attributeEnumValues AttributeEnumValue[]
  attributeEnumValueAliases AttributeEnumValueAlias[]
  integrations        Integration[]
  category            Category[]
  brands              Brand[]
  saleUnits           CatalogSaleUnit[]
  order               Order[]
  cart                Cart[]
  media               Media[]
  domains             CatalogDomain[]
  featureEntitlements CatalogFeatureEntitlement[]
  inventoryWarehouses InventoryWarehouseCatalog[]

  subscriptionEndsAt DateTime? @map("subscription_ends_at") // Дата окончания подписки

  deleteAt DateTime? @map("delete_at") // Дата удаления 

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([typeId])
  @@map("catalogs")
}

model CatalogSaleUnit {
  id String @id @default(uuid()) @db.Uuid

  catalogId String @map("catalog_id") @db.Uuid

  code                String  @db.VarChar(100)
  name                String  @db.VarChar(255)
  defaultBaseQuantity Decimal @default(1) @map("default_base_quantity") @db.Decimal(12, 4)
  barcode             String? @db.VarChar(100)

  isActive     Boolean @default(true) @map("is_active")
  displayOrder Int     @default(0) @map("display_order")

  deleteAt DateTime? @map("delete_at")

  catalog          Catalog                  @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  variantSaleUnits ProductVariantSaleUnit[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([catalogId, code])
  @@index([catalogId, isActive, displayOrder])
  @@index([catalogId, deleteAt])
  @@index([barcode])
  @@map("catalog_sale_units")
}

// Здесь основные ключи отображения
model CatalogFeatureEntitlement {
  id String @id @default(uuid()) @db.Uuid

  catalog   Catalog @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  catalogId String  @map("catalog_id") @db.Uuid

  feature   String    @db.VarChar(100)
  enabled   Boolean   @default(false)
  expiresAt DateTime? @map("expires_at")
  metadata  Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([catalogId, feature])
  @@index([feature, enabled])
  @@index([expiresAt])
  @@map("catalog_feature_entitlements")
}

model CatalogDomain {
  id String @id @default(uuid()) @db.Uuid

  catalog   Catalog @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  catalogId String  @map("catalog_id") @db.Uuid

  hostname String              @unique @db.VarChar(253)
  status   CatalogDomainStatus @default(PENDING_DNS)

  isPrimary         Boolean @default(false) @map("is_primary")
  redirectToPrimary Boolean @default(true) @map("redirect_to_primary")
  includeWww        Boolean @default(false) @map("include_www")

  verificationToken String    @map("verification_token") @db.VarChar(128)
  lastCheckedAt     DateTime? @map("last_checked_at")
  lastError         String?   @map("last_error")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([catalogId])
  @@index([status])
  @@map("catalog_domains")
}

model CatalogConfig {
  id String @id @default(uuid()) @db.Uuid

  catalogId String  @unique @map("catalog_id") @db.Uuid
  catalog   Catalog @relation(fields: [catalogId], references: [id], onDelete: Cascade)

  about String @default("")

  description String?

  currency String @default("₽")

  logoMediaId String? @map("logo_media_id") @db.Uuid
  bgMediaId   String? @map("bg_media_id") @db.Uuid

  logoMedia Media? @relation("CatalogConfigLogo", fields: [logoMediaId], references: [id], onDelete: SetNull)
  bgMedia   Media? @relation("CatalogConfigBg", fields: [bgMediaId], references: [id], onDelete: SetNull)

  status CatalogStatus @default(PROPOSAL)

  note String?

  deleteAt  DateTime? @map("delete_at") // Дата удаления 
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("catalog_configs")
}

model CatalogContact {
  id String @id @default(uuid()) @db.Uuid

  type     ContactType // PHONE, EMAIL, WHATSAPP, TELEGRAM
  position Int

  value String

  catalog   Catalog @relation(fields: [catalogId], references: [id])
  catalogId String  @map("catalog_id") @db.Uuid

  deleteAt  DateTime? @map("delete_at") // Дата удаления 
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("catalog_contacts")
}

// Здесь настройки бизнес логики
model CatalogSettings {
  id String @id @default(uuid()) @db.Uuid

  catalog   Catalog @relation(fields: [catalogId], references: [id])
  catalogId String  @unique @map("catalog_id") @db.Uuid

  isActive Boolean @default(true) @map("is_active")

  defaultMode   CatalogExperienceMode   @default(DELIVERY) @map("default_mode")
  allowedModes  CatalogExperienceMode[] @default([DELIVERY]) @map("allowed_modes")
  inventoryMode CatalogInventoryMode    @default(NONE) @map("inventory_mode")

  address  String? @map("address")
  checkout Json?

  googleVerification String? @map("google_verification")
  yandexVerification String? @map("yandex_verification")

  deleteAt  DateTime? @map("delete_at") // Дата удаления 
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("catalog_settings")
}
