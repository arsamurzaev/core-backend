model Metrics {
    id String @id @default(uuid()) @db.Uuid

    catalog   Catalog @relation(fields: [catalogId], references: [id])
    catalogId String  @map("catalog_id") @db.Uuid

    provider  Metric @default(YANDEX) // yandex, google, custom
    counterId String @default("104676804") @map("counter_id") // идентификатор счётчика

    deleteAt  DateTime? @map("delete_at") // Дата удаления 
    createdAt DateTime  @default(now()) @map("created_at")
    updatedAt DateTime  @updatedAt @map("updated_at")

    @@map("metrics")
}
