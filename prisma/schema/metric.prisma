model Metrics {
  id String @id @default(uuid()) @db.Uuid

  catalog   Catalog @relation(fields: [catalogId], references: [id])
  catalogId String  @map("catalog_id") @db.Uuid

  provider  Metric      @default(YANDEX)
  scope     MetricScope @default(CATALOG)
  counterId String      @map("counter_id")

  deleteAt  DateTime? @map("delete_at") // Дата удаления
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@unique([catalogId, provider, scope])
  @@map("metrics")
}
