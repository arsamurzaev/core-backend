model Order {
  id String @id @default(uuid()) @db.Uuid

  status OrderStatus @default(PENDING)

  legacyOrderId String? @map("legacy_order_id") @db.VarChar(191)
  legacyUserId  String? @map("legacy_user_id") @db.VarChar(191)

  token      String?
  comment    String?
  address    String?
  isDelivery Boolean @default(false) @map("is_delivery")

  commentByAdmin String? @map("comment_by_admin")

  paymentMethod PaymentMethod? @map("payment_method")
  paymentProof  String[]       @map("payment_proof")

  // Source of truth for both migrated and newly created orders.
  products Json

  totalAmount Decimal @default(0) @map("total_amount") @db.Decimal(12, 2)

  catalog   Catalog @relation(fields: [catalogId], references: [id])
  catalogId String  @map("catalog_id") @db.Uuid

  deleteAt  DateTime? @map("delete_at") // Дата удаления
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([catalogId, createdAt])
  @@index([catalogId, legacyOrderId])
  @@map("orders")
}
