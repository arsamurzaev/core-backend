model Order {
    id String @id @default(uuid()) @db.Uuid

    status OrderStatus @default(PENDING)

    token   String?
    comment String?

    commentByAdmin String? @map("comment_by_admin")

    paymentMethod PaymentMethod? @map("payment_method")
    paymentProof  String[]       @map("payment_proof")
    products      Json

    totalAmount Int @default(0) @map("total_amount")

    catalog   Catalog @relation(fields: [catalogId], references: [id])
    catalogId String  @map("catalog_id") @db.Uuid

    // ✅ позиции заказа
    items OrderItem[]

    deleteAt  DateTime? @map("delete_at") // Дата удаления 
    createdAt DateTime  @default(now()) @map("created_at")
    updatedAt DateTime  @updatedAt @map("updated_at")

    @@map("orders")
}

model OrderItem {
    id String @id @default(uuid()) @db.Uuid

    orderId String @map("order_id") @db.Uuid
    order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

    productId String  @map("product_id") @db.Uuid
    product   Product @relation(fields: [productId], references: [id])

    // если покупают конкретный вариант
    variantId String? @map("variant_id") @db.Uuid

    quantity Int @default(1)

    // цена на момент покупки (лучше хранить снапшотом)
    unitPrice Decimal @map("unit_price") @db.Decimal(12, 2)

    createdAt DateTime @default(now()) @map("created_at")

    @@index([orderId])
    @@index([productId, createdAt])
    @@index([variantId, createdAt])
    @@map("order_items")
}
