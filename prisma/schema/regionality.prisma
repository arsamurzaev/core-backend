model Regionality {
    id String @id @default(uuid()) @db.Uuid

    code String @unique
    name String

    catalogs Catalog[]

    deleteAt  DateTime? @map("delete_at") // Дата удаления 
    createdAt DateTime  @default(now()) @map("created_at")
    updatedAt DateTime  @updatedAt @map("updated_at")

    @@map("regionality")
}
