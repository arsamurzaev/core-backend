model User {
    id String @id @default(uuid()) @db.Uuid

    name String

    login    String
    password String

    role Role

    isEmailConfirmed Boolean

    catalogs Catalog[]
    regions  Regionality[]

    deleteAt  DateTime? @map("delete_at") // Дата удаления 
    createdAt DateTime  @default(now()) @map("created_at")
    updatedAt DateTime  @updatedAt @map("updated_at")

    @@unique([login, role])
    @@map("users")
}
