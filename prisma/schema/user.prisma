model User {
  id String @id @default(uuid()) @db.Uuid

  name String

  login    String
  password String

  email              String?
  phone              String?
  mustChangePassword Boolean @default(false) @map("must_change_password")

  role Role

  isEmailConfirmed Boolean

  catalogs            Catalog[]
  catalogSignups      CatalogSignup[]      @relation("CatalogSignupCreatedUser")
  countries           Country[]
  regions             Regionality[]
  inventoryWarehouses InventoryWarehouse[]
  inventoryMovements  InventoryMovement[]  @relation("InventoryMovementActor")

  deleteAt  DateTime? @map("delete_at") // Дата удаления 
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@unique([login, role])
  @@map("users")
}
