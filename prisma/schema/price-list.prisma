enum CatalogPriceListPriceTarget {
  PRODUCT
  VARIANT
  SALE_UNIT
}

model CatalogPriceList {
  id String @id @default(uuid()) @db.Uuid

  catalogId String  @map("catalog_id") @db.Uuid
  catalog   Catalog @relation(fields: [catalogId], references: [id], onDelete: Cascade)

  code        String  @db.VarChar(100)
  name        String  @db.VarChar(255)
  description String? @db.VarChar(1000)

  isActive     Boolean @default(true) @map("is_active")
  displayOrder Int     @default(0) @map("display_order")

  prices           CatalogPriceListPrice[]
  selectedSettings CatalogSettings[]
  cartItems        CartItem[]

  deleteAt DateTime? @map("delete_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([catalogId, code])
  @@index([catalogId, isActive, displayOrder])
  @@index([catalogId, deleteAt])
  @@map("catalog_price_lists")
}

model CatalogPriceListPrice {
  id String @id @default(uuid()) @db.Uuid

  priceListId String                      @map("price_list_id") @db.Uuid
  priceList   CatalogPriceList            @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  target      CatalogPriceListPriceTarget
  targetId    String                      @map("target_id") @db.Uuid

  productId  String  @map("product_id") @db.Uuid
  variantId  String? @map("variant_id") @db.Uuid
  saleUnitId String? @map("sale_unit_id") @db.Uuid

  product  Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant  ProductVariant?         @relation(fields: [variantId], references: [id], onDelete: Cascade)
  saleUnit ProductVariantSaleUnit? @relation(fields: [saleUnitId], references: [id], onDelete: Cascade)

  price Decimal @db.Decimal(12, 2)

  deleteAt DateTime? @map("delete_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([priceListId, target, targetId])
  @@index([priceListId, productId])
  @@index([priceListId, variantId])
  @@index([priceListId, saleUnitId])
  @@index([productId])
  @@index([variantId])
  @@index([saleUnitId])
  @@index([deleteAt])
  @@map("catalog_price_list_prices")
}
