// Здесь настройки интеграции
model Integration {
  id String @id @default(uuid()) @db.Uuid

  catalogId String              @map("catalog_id") @db.Uuid
  provider  IntegrationProvider

  metadata Json

  isActive Boolean @default(true) @map("is_active")

  syncStartedAt  DateTime?             @map("sync_started_at")
  lastSyncAt     DateTime?             @map("last_sync_at")
  lastSyncStatus IntegrationSyncStatus @default(IDLE) @map("last_sync_status")
  lastSyncError  String?               @map("last_sync_error") @db.Text

  totalProducts   Int @default(0) @map("total_products")
  createdProducts Int @default(0) @map("created_products")
  updatedProducts Int @default(0) @map("updated_products")
  deletedProducts Int @default(0) @map("deleted_products")

  catalog             Catalog                         @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  productLinks        IntegrationProductLink[]
  variantLinks        IntegrationVariantLink[]
  categoryLinks       IntegrationCategoryLink[]
  syncRuns            IntegrationSyncRun[]
  orderExports        IntegrationOrderExport[]
  webhookEvents       IntegrationWebhookEvent[]
  externalItems       IntegrationExternalItem[]
  externalObjects     IntegrationExternalObject[]
  entityMappings      IntegrationEntityMapping[]
  cartTableSessions   CartTableSession[]
  inventoryMovements  InventoryMovement[]
  modifierGroupLinks  IntegrationModifierGroupLink[]
  modifierOptionLinks IntegrationModifierOptionLink[]

  deleteAt  DateTime? @map("delete_at") // Дата удаления
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@unique([catalogId, provider])
  @@index([catalogId, isActive])
  @@index([lastSyncStatus, syncStartedAt])
  @@map("integrations")
}

model IntegrationExternalObject {
  id String @id @default(uuid()) @db.Uuid

  integrationId String @map("integration_id") @db.Uuid

  code     String                        @db.VarChar(191)
  name     String                        @db.VarChar(255)
  kind     IntegrationExternalObjectKind @default(CUSTOM)
  endpoint String?                       @db.VarChar(1000)
  method   String?                       @db.VarChar(16)
  schema   Json?
  sample   Json?

  isActive         Boolean   @default(true) @map("is_active")
  lastDiscoveredAt DateTime? @map("last_discovered_at")

  integration    Integration                @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  entityMappings IntegrationEntityMapping[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([integrationId, code])
  @@index([integrationId, kind, isActive])
  @@map("integration_external_objects")
}

model IntegrationEntityMapping {
  id String @id @default(uuid()) @db.Uuid

  integrationId    String  @map("integration_id") @db.Uuid
  externalObjectId String? @map("external_object_id") @db.Uuid

  localEntity        IntegrationMappingLocalEntity
  externalObjectCode String                        @map("external_object_code") @db.VarChar(191)
  identityField      String                        @map("identity_field") @db.VarChar(255)
  direction          IntegrationMappingDirection   @default(IMPORT)
  conflictPolicy     String?                       @map("conflict_policy") @db.VarChar(64)
  filters            Json?
  options            Json?
  isActive           Boolean                       @default(true) @map("is_active")

  integration    Integration                @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  externalObject IntegrationExternalObject? @relation(fields: [externalObjectId], references: [id], onDelete: SetNull)
  fieldMappings  IntegrationFieldMapping[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([integrationId, localEntity, externalObjectCode])
  @@index([integrationId, localEntity, isActive])
  @@index([externalObjectId])
  @@map("integration_entity_mappings")
}

model IntegrationFieldMapping {
  id String @id @default(uuid()) @db.Uuid

  entityMappingId String @map("entity_mapping_id") @db.Uuid

  localPath    String                      @map("local_path") @db.VarChar(255)
  externalPath String                      @map("external_path") @db.VarChar(500)
  direction    IntegrationMappingDirection @default(IMPORT)
  dataType     IntegrationMappingDataType  @default(STRING) @map("data_type")
  transform    Json?
  defaultValue Json?                       @map("default_value")
  isRequired   Boolean                     @default(false) @map("is_required")
  isActive     Boolean                     @default(true) @map("is_active")
  displayOrder Int                         @default(0) @map("display_order")

  entityMapping IntegrationEntityMapping @relation(fields: [entityMappingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([entityMappingId, localPath, externalPath])
  @@index([entityMappingId, isActive, displayOrder])
  @@map("integration_field_mappings")
}

model IntegrationExternalItem {
  id String @id @default(uuid()) @db.Uuid

  catalogId     String              @map("catalog_id") @db.Uuid
  integrationId String              @map("integration_id") @db.Uuid
  provider      IntegrationProvider

  type             String  @db.VarChar(64)
  externalId       String  @map("external_id") @db.VarChar(128)
  externalParentId String? @map("external_parent_id") @db.VarChar(128)
  publicCode       String  @unique @map("public_code") @db.VarChar(32)
  name             String? @db.VarChar(255)
  code             String? @db.VarChar(128)
  isActive         Boolean @default(true) @map("is_active")
  rawMeta          Json?   @map("raw_meta")

  lastSeenAt   DateTime? @map("last_seen_at")
  lastSyncedAt DateTime? @map("last_synced_at")

  catalog       Catalog            @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  integration   Integration        @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  tableSessions CartTableSession[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([integrationId, type, externalId])
  @@index([catalogId, provider, type])
  @@index([integrationId, type, externalParentId])
  @@map("integration_external_items")
}

model IntegrationProductLink {
  id String @id @default(uuid()) @db.Uuid

  integrationId String @map("integration_id") @db.Uuid
  productId     String @map("product_id") @db.Uuid

  externalId        String    @map("external_id") @db.VarChar(128)
  externalCode      String?   @map("external_code") @db.VarChar(100)
  externalUpdatedAt DateTime? @map("external_updated_at")
  lastSyncedAt      DateTime? @map("last_synced_at")
  lastSeenAt        DateTime? @map("last_seen_at")
  lastPriceSyncAt   DateTime? @map("last_price_sync_at")
  lastStockSyncAt   DateTime? @map("last_stock_sync_at")
  missingSince      DateTime? @map("missing_since")
  missingSyncCount  Int       @default(0) @map("missing_sync_count")
  skippedReason     String?   @map("skipped_reason") @db.VarChar(191)
  lastExternalError String?   @map("last_external_error") @db.Text
  rawMeta           Json?     @map("raw_meta")

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([integrationId, externalId])
  @@unique([integrationId, productId])
  @@index([productId])
  @@index([integrationId, missingSince])
  @@map("integration_product_links")
}

model IntegrationVariantLink {
  id String @id @default(uuid()) @db.Uuid

  integrationId String @map("integration_id") @db.Uuid
  variantId     String @map("variant_id") @db.Uuid

  externalId        String    @map("external_id") @db.VarChar(128)
  externalCode      String?   @map("external_code") @db.VarChar(100)
  externalUpdatedAt DateTime? @map("external_updated_at")
  lastSyncedAt      DateTime? @map("last_synced_at")
  lastSeenAt        DateTime? @map("last_seen_at")
  lastPriceSyncAt   DateTime? @map("last_price_sync_at")
  lastStockSyncAt   DateTime? @map("last_stock_sync_at")
  missingSince      DateTime? @map("missing_since")
  missingSyncCount  Int       @default(0) @map("missing_sync_count")
  skippedReason     String?   @map("skipped_reason") @db.VarChar(191)
  lastExternalError String?   @map("last_external_error") @db.Text
  rawMeta           Json?     @map("raw_meta")

  integration Integration    @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([integrationId, externalId])
  @@unique([integrationId, variantId])
  @@index([variantId])
  @@index([integrationId, missingSince])
  @@map("integration_variant_links")
}

model IntegrationCategoryLink {
  id String @id @default(uuid()) @db.Uuid

  integrationId String @map("integration_id") @db.Uuid
  categoryId    String @map("category_id") @db.Uuid

  externalId       String  @map("external_id") @db.VarChar(64)
  externalParentId String? @map("external_parent_id") @db.VarChar(64)
  rawMeta          Json?   @map("raw_meta")

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([integrationId, externalId])
  @@unique([integrationId, categoryId])
  @@index([categoryId])
  @@index([externalParentId])
  @@map("integration_category_links")
}

model IntegrationSyncRun {
  id String @id @default(uuid()) @db.Uuid

  integrationId String @map("integration_id") @db.Uuid
  catalogId     String @map("catalog_id") @db.Uuid

  provider             IntegrationProvider
  mode                 IntegrationSyncRunMode
  trigger              IntegrationSyncRunTrigger
  status               IntegrationSyncRunStatus            @default(PENDING)
  snapshotCompleteness IntegrationSyncSnapshotCompleteness @default(PARTIAL) @map("snapshot_completeness")

  jobId      String? @unique @map("job_id") @db.VarChar(191)
  productId  String? @map("product_id") @db.Uuid
  externalId String? @map("external_id") @db.VarChar(64)
  error      String? @db.Text
  metadata   Json?

  totalProducts   Int  @default(0) @map("total_products")
  createdProducts Int  @default(0) @map("created_products")
  updatedProducts Int  @default(0) @map("updated_products")
  deletedProducts Int  @default(0) @map("deleted_products")
  imagesImported  Int  @default(0) @map("images_imported")
  durationMs      Int? @map("duration_ms")

  requestedAt DateTime  @default(now()) @map("requested_at")
  startedAt   DateTime? @map("started_at")
  finishedAt  DateTime? @map("finished_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId, requestedAt])
  @@index([catalogId, provider, requestedAt])
  @@index([status, requestedAt])
  @@index([productId, requestedAt])
  @@map("integration_sync_runs")
}

model IntegrationOrderExport {
  id String @id @default(uuid()) @db.Uuid

  integrationId String @map("integration_id") @db.Uuid
  orderId       String @map("order_id") @db.Uuid

  provider       IntegrationProvider
  idempotencyKey String                       @unique @map("idempotency_key") @db.VarChar(191)
  externalId     String?                      @map("external_id") @db.VarChar(64)
  status         IntegrationOrderExportStatus @default(PENDING)
  attempts       Int                          @default(0)
  lastError      String?                      @map("last_error") @db.Text
  payload        Json?
  response       Json?

  requestedAt DateTime  @default(now()) @map("requested_at")
  startedAt   DateTime? @map("started_at")
  exportedAt  DateTime? @map("exported_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([integrationId, orderId])
  @@index([orderId])
  @@index([status, requestedAt])
  @@index([integrationId, status, requestedAt])
  @@map("integration_order_exports")
}

model IntegrationWebhookEvent {
  id String @id @default(uuid()) @db.Uuid

  integrationId String              @map("integration_id") @db.Uuid
  provider      IntegrationProvider

  requestId String @map("request_id") @db.VarChar(191)
  reportUrl String @map("report_url") @db.VarChar(1000)

  payload Json?
  status  IntegrationWebhookEventStatus @default(PENDING)
  jobId   String?                       @map("job_id") @db.VarChar(191)
  error   String?                       @db.Text

  receivedAt  DateTime  @default(now()) @map("received_at")
  processedAt DateTime? @map("processed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([integrationId, requestId])
  @@index([integrationId, status, receivedAt])
  @@index([provider, status, receivedAt])
  @@map("integration_webhook_events")
}
