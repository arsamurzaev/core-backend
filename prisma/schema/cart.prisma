model Cart {
  id String @id @default(uuid()) @db.Uuid

  items                 CartItem[]
  tableSession          CartTableSession?
  inventoryMovements    InventoryMovement[]
  inventoryReservations InventoryReservation[]

  userId String? @map("user_id") @db.Uuid
  token  String?

  status          CartStatus @default(DRAFT)
  statusChangedAt DateTime   @default(now()) @map("status_changed_at")

  publicKey   String?   @unique @map("public_key")
  checkoutKey String?   @map("checkout_key")
  checkoutAt  DateTime? @map("checkout_at")
  comment     String?

  checkoutMethod   CartCheckoutMethod? @map("checkout_method")
  checkoutData     Json?               @map("checkout_data")
  checkoutContacts Json?               @map("checkout_contacts")

  assignedManagerId       String?   @map("assigned_manager_id") @db.Uuid
  managerSessionStartedAt DateTime? @map("manager_session_started_at")
  managerLastSeenAt       DateTime? @map("manager_last_seen_at")
  closedAt                DateTime? @map("closed_at")

  catalog   Catalog @relation(fields: [catalogId], references: [id])
  catalogId String  @map("catalog_id") @db.Uuid

  deleteAt  DateTime? @map("delete_at") // Дата удаления 
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([status, managerLastSeenAt])
  @@map("carts")
}

model CartItem {
  id String @id @default(uuid()) @db.Uuid

  product   Product @relation(fields: [productId], references: [id])
  productId String  @map("product_id") @db.Uuid

  quantity          Int      @default(1)
  baseQuantity      Int?     @map("base_quantity")
  unitPriceSnapshot Decimal? @map("unit_price_snapshot") @db.Decimal(12, 2)
  guestSessionId    String?  @map("guest_session_id") @db.VarChar(64)
  guestName         String?  @map("guest_name") @db.VarChar(120)

  cart   Cart   @relation(fields: [cartId], references: [id])
  cartId String @map("cart_id") @db.Uuid

  variant               ProductVariant?         @relation(fields: [variantId], references: [id], onDelete: SetNull)
  variantId             String?                 @map("variant_id") @db.Uuid
  saleUnit              ProductVariantSaleUnit? @relation(fields: [saleUnitId], references: [id], onDelete: SetNull)
  saleUnitId            String?                 @map("sale_unit_id") @db.Uuid
  inventoryReservations InventoryReservation[]

  deleteAt  DateTime? @map("delete_at") // Дата удаления 
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([cartId, deleteAt])
  @@index([cartId, guestSessionId, deleteAt])
  @@index([variantId])
  @@index([saleUnitId])
  @@map("cart_items")
}

model CartTableSession {
  id String @id @default(uuid()) @db.Uuid

  catalogId           String  @map("catalog_id") @db.Uuid
  integrationId       String  @map("integration_id") @db.Uuid
  cartId              String  @unique @map("cart_id") @db.Uuid
  externalTableItemId String? @map("external_table_item_id") @db.Uuid
  submittedOrderId    String? @map("submitted_order_id") @db.Uuid

  provider  IntegrationProvider    @default(IIKO)
  status    CartTableSessionStatus @default(OPEN)
  activeKey String?                @unique @map("active_key") @db.VarChar(255)

  publicCode        String  @map("public_code") @db.VarChar(32)
  tableExternalId   String  @map("table_external_id") @db.VarChar(128)
  tableNumber       String? @map("table_number") @db.VarChar(64)
  tableName         String? @map("table_name") @db.VarChar(255)
  sectionExternalId String? @map("section_external_id") @db.VarChar(128)
  sectionName       String? @map("section_name") @db.VarChar(255)
  guestsCount       Int?    @map("guests_count")

  externalOrderId       String? @map("external_order_id") @db.VarChar(128)
  externalCorrelationId String? @map("external_correlation_id") @db.VarChar(128)
  metadata              Json?

  submittedAt DateTime? @map("submitted_at")
  closedAt    DateTime? @map("closed_at")

  catalog           Catalog                  @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  integration       Integration              @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  cart              Cart                     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  externalTableItem IntegrationExternalItem? @relation(fields: [externalTableItemId], references: [id], onDelete: SetNull)
  submittedOrder    Order?                   @relation("CartTableSessionSubmittedOrder", fields: [submittedOrderId], references: [id], onDelete: SetNull)

  deleteAt  DateTime? @map("delete_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([catalogId, provider, tableExternalId, status])
  @@index([integrationId, status])
  @@index([submittedOrderId])
  @@index([externalTableItemId])
  @@map("cart_table_sessions")
}
