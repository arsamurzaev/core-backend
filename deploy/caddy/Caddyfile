# Production Caddyfile для платформенного домена.
#
# Схема:
#   Internet :80/:443 -> Caddy
#   Caddy /_svc_api/* -> backend 127.0.0.1:4000
#   Caddy /*          -> public frontend 127.0.0.1:3000
#   Caddy shtab.*     -> admin frontend 127.0.0.1:3001
#
# Домен и пути к сертификату задаются через systemd EnvironmentFile:
#
#   CATALOG_PLATFORM_DOMAIN=myctlg-update.ru
#   CADDY_ACME_EMAIL=admin@myctlg-update.ru
#   CADDY_PLATFORM_CERT_FULLCHAIN=/etc/caddy/certs/myctlg-update.ru.crt
#   CADDY_PLATFORM_CERT_KEY=/etc/caddy/certs/myctlg-update.ru.key

{
	email {$CADDY_ACME_EMAIL:admin@myctlg-update.ru}

	on_demand_tls {
		ask http://127.0.0.1:4000/internal/tls/ask
	}
}

(access_log) {
	log {
		output file /var/log/caddy/catalog-access.log {
			roll_size 100MiB
			roll_keep 10
			roll_keep_for 720h
		}
		format json
	}
}

(platform_headers) {
	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"
	}
}

(custom_domain_headers) {
	header {
		Strict-Transport-Security "max-age=31536000"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"
	}
}

(strip_upstream_security_headers) {
	header_down -Strict-Transport-Security
	header_down -X-Content-Type-Options
	header_down -X-Frame-Options
	header_down -Referrer-Policy
	header_down -Permissions-Policy
}

(backend_proxy) {
	reverse_proxy 127.0.0.1:4000 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}

		import strip_upstream_security_headers

		flush_interval -1
		stream_close_delay 5m

		transport http {
			dial_timeout 10s
			response_header_timeout 120s
		}
	}
}

(public_frontend_proxy) {
	reverse_proxy 127.0.0.1:3000 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}

		import strip_upstream_security_headers

		transport http {
			dial_timeout 10s
			response_header_timeout 180s
		}
	}
}

(admin_frontend_proxy) {
	reverse_proxy 127.0.0.1:3001 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}

		import strip_upstream_security_headers

		transport http {
			dial_timeout 10s
			response_header_timeout 180s
		}
	}
}

(common_site) {
	encode zstd gzip
	import access_log

	request_body {
		max_size 25MB
	}

	handle /internal/* {
		respond 404
	}

	handle /_svc_api/internal/* {
		respond 404
	}

	handle /api/internal/* {
		respond 404
	}
}

(svc_api_to_backend) {
	@svc_api {
		path /_svc_api /_svc_api/*
		not path /_svc_api/internal /_svc_api/internal/*
	}
	handle @svc_api {
		uri strip_prefix /_svc_api
		import backend_proxy
	}
}

shtab.{$CATALOG_PLATFORM_DOMAIN:myctlg-update.ru} {
	tls {$CADDY_PLATFORM_CERT_FULLCHAIN:/etc/caddy/certs/myctlg-update.ru.crt} {$CADDY_PLATFORM_CERT_KEY:/etc/caddy/certs/myctlg-update.ru.key}
	import svc_api_to_backend
	import common_site
	import platform_headers

	handle {
		import admin_frontend_proxy
	}
}

api.{$CATALOG_PLATFORM_DOMAIN:myctlg-update.ru} {
	tls {$CADDY_PLATFORM_CERT_FULLCHAIN:/etc/caddy/certs/myctlg-update.ru.crt} {$CADDY_PLATFORM_CERT_KEY:/etc/caddy/certs/myctlg-update.ru.key}
	import svc_api_to_backend
	import common_site
	import platform_headers

	handle {
		import backend_proxy
	}
}

{$CATALOG_PLATFORM_DOMAIN:myctlg-update.ru}, *.{$CATALOG_PLATFORM_DOMAIN:myctlg-update.ru} {
	tls {$CADDY_PLATFORM_CERT_FULLCHAIN:/etc/caddy/certs/myctlg-update.ru.crt} {$CADDY_PLATFORM_CERT_KEY:/etc/caddy/certs/myctlg-update.ru.key}
	import svc_api_to_backend
	import common_site
	import platform_headers

	handle {
		import public_frontend_proxy
	}
}

# Кастомные домены клиентов.
# Caddy выпускает сертификат только если backend разрешил домен:
#   GET http://127.0.0.1:4000/internal/tls/ask?domain=kingsname.ru
https:// {
	tls {
		on_demand
	}

	import svc_api_to_backend
	import common_site
	import custom_domain_headers

	handle {
		import public_frontend_proxy
	}
}

http:// {
	redir https://{host}{uri} permanent
}
