OBSERVABILITY_HOST_BIND_IP=0.0.0.0

GRAFANA_PORT=3001
OBSERVABILITY_LOKI_PORT=3100
OBSERVABILITY_TEMPO_OTLP_GRPC_PORT=4317
OBSERVABILITY_TEMPO_OTLP_HTTP_PORT=4318
OBSERVABILITY_MIMIR_PORT=9009

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me

# Recommended firewall policy:
# - allow Grafana only from your admin IP/VPN
# - allow Loki/Mimir/Tempo ingest only from the backend host IP
