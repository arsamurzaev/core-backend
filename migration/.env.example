# Separate env file for legacy migration.
# Loading order:
# 1. .env
# 2. migration/.env
# 3. migration/.env.local
#
# This means you can keep your regular backend config in `.env`
# and place only migration-specific overrides here.

# Legacy source database
LEGACY_DATABASE_URL="postgresql://reader:password@host:5432/legacy_db"
LEGACY_DATABASE_SSL_MODE="no-verify"


# If the legacy PostgreSQL uses a self-signed certificate, uncomment one of:
# LEGACY_DATABASE_SSL_MODE="no-verify"
# LEGACY_DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Optional: allow larger legacy source images during media migration.
# This does not change the regular backend upload limit.
# LEGACY_MIGRATION_MEDIA_MAX_FILE_MB="100"

# Optional: override target database for migration only
# DATABASE_URI=""

# Optional: if you prefer a different variable name
# LEGACY_DATABASE_URI=""
# OLD_DATABASE_URL=""
