{
	"name": "backend",
	"version": "0.0.1",
	"description": "",
	"author": "",
	"private": true,
	"license": "UNLICENSED",
	"scripts": {
		"prebuild": "prisma generate",
		"build": "nest build",
		"format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
		"start": "nest start",
		"start:dev": "nest start --watch",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node dist/main",
		"lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:cov": "jest --coverage",
		"test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
		"test:e2e": "jest --config ./test/jest-e2e.json",
		"prisma:push": "prisma db push",
		"prisma:generate": "prisma generate",
		"legacy:migrate": "tsc -p migration/tsconfig.json && node migration/dist/migration/scripts/migrate-legacy.js",
		"legacy:migrate:all": "tsc -p migration/tsconfig.json && node migration/dist/migration/scripts/migrate-legacy.js --phase=all --apply"
	},
	"prisma": {
		"seed": "node --loader ts-node/esm prisma/seed.ts"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.986.0",
		"@aws-sdk/s3-presigned-post": "^3.986.0",
		"@aws-sdk/s3-request-presigner": "^3.986.0",
		"@nestjs/common": "^11.1.11",
		"@nestjs/config": "^4.0.2",
		"@nestjs/core": "^11.1.11",
		"@nestjs/mapped-types": "*",
		"@nestjs/platform-express": "^11.1.11",
		"@nestjs/schedule": "^6.1.1",
		"@nestjs/swagger": "^11.2.4",
		"@nestjs/throttler": "^6.5.0",
		"@opentelemetry/api": "^1.9.1",
		"@opentelemetry/auto-instrumentations-node": "^0.72.0",
		"@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
		"@opentelemetry/sdk-node": "^0.214.0",
		"@opentelemetry/semantic-conventions": "^1.40.0",
		"@prisma/adapter-pg": "^7.2.0",
		"@prisma/client": "^7.2.0",
		"argon2": "^0.44.0",
		"bottleneck": "^2.19.5",
		"bullmq": "^5.67.3",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.14.3",
		"compression": "^1.8.1",
		"dotenv": "^17.2.3",
		"geoip-lite": "^1.4.10",
		"helmet": "^8.1.0",
		"ioredis": "^5.9.1",
		"p-limit": "^7.3.0",
		"prisma": "^7.2.0",
		"prom-client": "^15.1.3",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.1",
		"sharp": "^0.34.5",
		"slugify": "^1.6.6",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.2.0",
		"@eslint/js": "^9.39.2",
		"@nestjs/cli": "^11.0.0",
		"@nestjs/schematics": "^11.0.0",
		"@nestjs/testing": "^11.1.11",
		"@trivago/prettier-plugin-sort-imports": "^6.0.2",
		"@types/compression": "^1.8.1",
		"@types/express": "^5.0.0",
		"@types/jest": "^30.0.0",
		"@types/node": "^22.19.5",
		"@types/supertest": "^6.0.2",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-prettier": "^5.2.2",
		"globals": "^16.0.0",
		"jest": "^30.0.0",
		"prettier": "^3.4.2",
		"source-map-support": "^0.5.21",
		"supertest": "^7.0.0",
		"ts-jest": "^29.2.5",
		"ts-loader": "^9.5.2",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.7.3",
		"typescript-eslint": "^8.20.0"
	},
	"jest": {
		"moduleFileExtensions": [
			"js",
			"json",
			"ts"
		],
		"rootDir": "src",
		"testRegex": ".*\\.spec\\.ts$",
		"transform": {
			"^.+\\.(t|j)s$": "ts-jest"
		},
		"collectCoverageFrom": [
			"**/*.(t|j)s"
		],
		"coverageDirectory": "../coverage",
		"testEnvironment": "node",
		"moduleNameMapper": {
			"^@/(.*)$": "<rootDir>/$1",
			"^@generated$": "<rootDir>/../prisma/generated",
			"^@generated/(.*)$": "<rootDir>/../prisma/generated/$1",
			"^(\\.{1,2}/.*)\\.js$": "$1"
		}
	}
}
