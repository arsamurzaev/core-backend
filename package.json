{
	"name": "backend",
	"version": "0.0.1",
	"description": "",
	"author": "",
	"private": true,
	"license": "UNLICENSED",
	"scripts": {
		"prebuild": "prisma generate",
		"build": "nest build",
		"format": "prettier --write --end-of-line crlf \"src/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.ts\" \"*.{ts,js,json}\" && prisma format --schema prisma/schema",
		"format:check": "prettier --check --end-of-line crlf \"src/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.ts\" \"*.{ts,js,json}\" && prisma validate --schema prisma/schema",
		"start": "nest start",
		"start:dev": "nest start --watch",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node dist/main",
		"lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:cov": "jest --coverage",
		"test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
		"test:e2e": "jest --config ./test/jest-e2e.json",
		"prisma:push": "prisma db push",
		"prisma:generate": "prisma generate",
		"prestart": "prisma generate",
		"prestart:dev": "prisma generate",
		"prestart:debug": "prisma generate",
		"db:console": "bun run scripts/db-console.ts",
		"db:console:test": "bun run scripts/db-console/self-test.ts",
		"db:audit-default-variants": "bun run scripts/audit-default-product-variants.ts",
		"db:nullify-zero-prices": "bun run scripts/nullify-zero-product-prices.ts",
		"openapi:export": "bun run scripts/export-openapi.ts",
		"prod:check": "bun run scripts/prod-quality-gate.ts",
		"iiko:smoke": "bun run scripts/iiko-external-menu-smoke.ts",
		"iiko:sync-once": "bun run scripts/iiko-sync-once.ts",
		"admin:create": "bun run scripts/create-admin.ts",
		"legacy:migrate": "tsc -p migration/tsconfig.json && node migration/dist/migration/scripts/migrate-legacy.js",
		"legacy:migrate:all": "tsc -p migration/tsconfig.json && node migration/dist/migration/scripts/migrate-legacy.js --phase=all --apply",
		"legacy:backfill-media-maps": "tsc -p migration/tsconfig.json && node migration/dist/migration/scripts/backfill-media-maps.js",
		"legacy:backfill-product-descriptions": "tsc -p migration/tsconfig.json && node migration/dist/migration/scripts/backfill-product-descriptions.js",
		"legacy:rebuild-product-seo": "tsc -p migration/tsconfig.json && node migration/dist/migration/scripts/rebuild-product-seo.js"
	},
	"prisma": {
		"seed": "node --loader ts-node/esm prisma/seed.ts"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1064.0",
		"@aws-sdk/s3-presigned-post": "^3.1064.0",
		"@aws-sdk/s3-request-presigner": "^3.1064.0",
		"@inquirer/prompts": "^8.5.2",
		"@nestjs/common": "^11.1.26",
		"@nestjs/config": "^4.0.4",
		"@nestjs/core": "^11.1.26",
		"@nestjs/mapped-types": "^2.1.1",
		"@nestjs/platform-express": "^11.1.26",
		"@nestjs/schedule": "^6.1.3",
		"@nestjs/swagger": "^11.4.4",
		"@nestjs/throttler": "^6.5.0",
		"@opentelemetry/api": "^1.9.1",
		"@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
		"@opentelemetry/resources": "^2.7.1",
		"@opentelemetry/sdk-trace-base": "^2.7.1",
		"@opentelemetry/sdk-trace-node": "^2.7.1",
		"@opentelemetry/semantic-conventions": "^1.41.1",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@react-email/components": "^1.0.12",
		"argon2": "^0.44.0",
		"bottleneck": "^2.19.5",
		"bullmq": "^5.78.0",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.14.4",
		"cli-table3": "^0.6.5",
		"commander": "^14.0.3",
		"compression": "^1.8.1",
		"dotenv": "^17.4.2",
		"geoip-lite": "^1.4.10",
		"helmet": "^8.2.0",
		"ioredis": "^5.11.1",
		"jspdf": "4.2.1",
		"nodemailer": "^9.0.1",
		"p-limit": "^7.3.0",
		"prisma": "^7.8.0",
		"prom-client": "^15.1.3",
		"react": "18.2.0",
		"react-dom": "18.2.0",
		"react-email": "^6.6.3",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.2",
		"sharp": "^0.34.5",
		"slugify": "^1.6.9",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/js": "^9.39.4",
		"@nestjs/cli": "^11.0.23",
		"@nestjs/schematics": "^11.1.0",
		"@nestjs/testing": "^11.1.26",
		"@trivago/prettier-plugin-sort-imports": "^6.0.2",
		"@types/compression": "^1.8.1",
		"@types/express": "^5.0.6",
		"@types/jest": "^30.0.0",
		"@types/multer": "^2.1.0",
		"@types/node": "^22.19.20",
		"@types/nodemailer": "^8.0.1",
		"@types/react": "18.3.31",
		"@types/react-dom": "18.3.7",
		"@types/supertest": "^6.0.3",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-prettier": "^5.5.6",
		"globals": "^16.5.0",
		"jest": "^30.4.2",
		"prettier": "^3.8.4",
		"source-map-support": "^0.5.21",
		"supertest": "^7.2.2",
		"ts-jest": "^29.4.11",
		"ts-loader": "^9.6.0",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.61.0"
	},
	"overrides": {
		"fast-uri": "^4.0.0",
		"flatted": "^3.4.2",
		"lodash": "^4.18.1",
		"lodash-es": "^4.18.1",
		"path-to-regexp": "^8.4.2",
		"qs": "^6.15.2"
	},
	"jest": {
		"moduleFileExtensions": [
			"ts",
			"tsx",
			"js",
			"json",
			"node"
		],
		"rootDir": "src",
		"testRegex": ".*\\.spec\\.ts$",
		"transform": {
			"^.+\\.(t|j)sx?$": "ts-jest"
		},
		"collectCoverageFrom": [
			"**/*.(t|j)s"
		],
		"coverageDirectory": "../coverage",
		"testEnvironment": "node",
		"moduleNameMapper": {
			"^@/(.*)$": "<rootDir>/$1",
			"^@generated$": "<rootDir>/../prisma/generated",
			"^@generated/(.*)$": "<rootDir>/../prisma/generated/$1",
			"^(\\.{1,2}/.*)\\.js$": "$1"
		}
	}
}
