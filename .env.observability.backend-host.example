OBSERVABILITY_ENABLED=true
OBSERVABILITY_SERVICE_NAME=catalog_backend
OBSERVABILITY_SERVICE_VERSION=0.0.1
OBSERVABILITY_DEPLOYMENT_ENVIRONMENT=production

OBSERVABILITY_JSON_LOGS=true
OBSERVABILITY_LOG_FILE_PATH=runtime/logs/backend.jsonl

OBSERVABILITY_METRICS_ENABLED=true
OBSERVABILITY_METRICS_PATH=/metrics

OBSERVABILITY_TRACES_ENABLED=true
OBSERVABILITY_OTLP_TRACES_URL=http://127.0.0.1:4318/v1/traces

OBSERVABILITY_APP_METRICS_TARGET=host.docker.internal:4000
OBSERVABILITY_ALLOY_LOG_GLOB=/workspace/runtime/logs/*.jsonl

# Replace obs.example.com with your observability server hostname or IP.
OBSERVABILITY_TEMPO_OTLP_ENDPOINT=obs.example.com:4317
OBSERVABILITY_MIMIR_REMOTE_WRITE_URL=http://obs.example.com:9009/api/v1/push
OBSERVABILITY_LOKI_WRITE_URL=http://obs.example.com:3100/loki/api/v1/push

ALLOY_OTLP_GRPC_PORT=4317
ALLOY_OTLP_HTTP_PORT=4318
ALLOY_HTTP_PORT=12345
